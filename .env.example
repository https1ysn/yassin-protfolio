# ── Supabase ─────────────────────────────────────────────────────────
# All three values: Supabase dashboard → Project Settings → API Keys
# (Project URL is on the same page.)

# Project URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Publishable key (starts with sb_publishable_...)
# Safe to expose to the browser — row-level security protects your data.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Secret key (starts with sb_secret_...)
# ONLY used by `npm run seed` on your machine. Never commit it and never
# add it to Vercel.
SUPABASE_SECRET_KEY=

# Legacy JWT-based keys are also supported if your project still uses them:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# ── Site URL (SEO) ───────────────────────────────────────────────────
# Your production origin, e.g. https://yassine.dev — used to build absolute
# canonical/hreflang/Open Graph URLs. Optional on Vercel (auto-detected) and
# overridden by the Canonical URL field in Admin → SEO.
NEXT_PUBLIC_SITE_URL=
